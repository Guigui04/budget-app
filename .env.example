# ─────────────────────────────────────────────────────────────
# Frontend (PWA) — only public keys. NEVER put server secrets here.
# Without these, the app runs in DEMO mode (in-memory dataset).
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Public VAPID key for Web Push (the private key lives in Supabase secrets).
VITE_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────
# Server-only secrets — set via `supabase secrets set ...`, NOT here.
# Listed for documentation only. Never expose to the PWA.
# ─────────────────────────────────────────────────────────────
# ENABLE_BANKING_APP_ID=
# ENABLE_BANKING_PRIVATE_KEY=          # RSA private key (PEM)
# ENABLE_BANKING_REDIRECT_URL=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# SUPABASE_SERVICE_ROLE_KEY=
